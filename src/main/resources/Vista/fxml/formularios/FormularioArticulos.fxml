<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="480.0" spacing="20.0" styleClass="vbox-main" stylesheets="/Vista/css/estilos.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Vista.controllers.formularios.FormularioArticuloController">

    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <Label text="NUEVO ARTÍCULO" styleClass="label-titulo"/>

    <GridPane vgap="15" hgap="15">
        <columnConstraints>
            <ColumnConstraints minWidth="140" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <children>
            <Label text="Código:" styleClass="label-cuerpo" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="txtCodigo" styleClass="text-field-steam" promptText="A001" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Descripción:" styleClass="label-cuerpo" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="txtDescripcion" styleClass="text-field-steam" promptText="Descripción del producto" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Precio Venta:" styleClass="label-cuerpo" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="txtPrecio" styleClass="text-field-steam" promptText="0.00" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Gastos Envío:" styleClass="label-cuerpo" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="txtEnvio" styleClass="text-field-steam" promptText="0.00" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Tiempo Prep (min):" styleClass="label-cuerpo" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="txtPreparacion" styleClass="text-field-steam" promptText="15" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label text="Stock Inicial:" styleClass="label-cuerpo" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <TextField fx:id="txtStock" styleClass="text-field-steam" promptText="0" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
        </children>
    </GridPane>

    <HBox spacing="15" alignment="CENTER">
        <Button text="CANCELAR" onAction="#cancelar" styleClass="boton-eliminar"/>
        <Button text="GUARDAR ARTÍCULO" onAction="#guardar" styleClass="boton-resaltado"/>
    </HBox>
</VBox>