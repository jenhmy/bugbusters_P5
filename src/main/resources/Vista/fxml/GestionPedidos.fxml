<?xml version="1.0" encoding="UTF-8"?>

<!-- Importaciones de JavaFX utilizadas en esta vista -->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!-- Vista de gestión de pedidos -->
<VBox prefHeight="600.0"
      prefWidth="1127.0"
      spacing="10.0"
      styleClass="vbox-main"
      stylesheets="/Vista/css/estilos.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Vista.controllers.GestionPedidosController">

    <children>

        <!-- CABECERA SUPERIOR CON TÍTULO Y ACCIONES -->
        <VBox alignment="CENTER_LEFT"
              prefHeight="120.0"
              spacing="10.0"
              styleClass="header-bar">

            <children>

                <!-- Título de la pantalla -->
                <Label styleClass="label-titulo" text="GESTIÓN DE PEDIDOS">
                    <VBox.margin>
                        <Insets left="20.0" />
                    </VBox.margin>
                </Label>

                <!-- Barra de acciones -->
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>

                        <!-- Botón para abrir formulario de creación -->
                        <Button onAction="#mostrarFormulario"
                                styleClass="boton-resaltado"
                                text="🛒 CREAR" />

                        <!-- Filtro de pedidos -->
                        <ComboBox fx:id="comboFiltro"
                                  prefWidth="180.0"
                                  promptText="Filtrar por..."
                                  styleClass="combo-box-steam" />

                        <!-- Buscador oculto/activable -->
                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                            <children>
                                <TextField fx:id="txtBuscador"
                                           managed="false"
                                           prefWidth="200.0"
                                           promptText="ID de pedido..."
                                           styleClass="text-field-steam"
                                           visible="false" />

                                <Button fx:id="btnLupa"
                                        onAction="#activarBuscador"
                                        styleClass="boton-primario"
                                        text="🔎" />
                            </children>
                        </HBox>

                        <!-- Acciones sobre pedidos -->
                        <Button onAction="#cambiarAEnviado"
                                styleClass="boton-primario"
                                text="CAMBIAR A ENVIADO" />

                        <Button onAction="#eliminarElemento"
                                styleClass="boton-eliminar"
                                text="CANCELAR" />

                    </children>

                    <VBox.margin>
                        <Insets left="20.0" />
                    </VBox.margin>
                </HBox>

                <!-- Mensajes de estado o confirmación -->
                <Label fx:id="lblMensaje"
                       styleClass="mensaje-confirmacion">
                    <VBox.margin>
                        <Insets left="20.0" />
                    </VBox.margin>
                </Label>

            </children>

            <padding>
                <Insets bottom="10.0" top="10.0" />
            </padding>
        </VBox>

        <!-- ZONA CENTRAL: TABLA DE PEDIDOS -->
        <StackPane VBox.vgrow="ALWAYS">

            <children>

                <AnchorPane styleClass="table-container">

                    <children>

                        <!-- Tabla principal de pedidos -->
                        <TableView fx:id="tvTabla"
                                   AnchorPane.bottomAnchor="15.0"
                                   AnchorPane.leftAnchor="15.0"
                                   AnchorPane.rightAnchor="15.0"
                                   AnchorPane.topAnchor="15.0">

                            <columns>

                                <!-- Columnas de la tabla -->
                                <TableColumn fx:id="colId" text="ID" prefWidth="60.0" />
                                <TableColumn fx:id="colCliente" text="CLIENTE" prefWidth="150.0" />
                                <TableColumn fx:id="colArticulo" text="ARTÍCULO" prefWidth="150.0" />
                                <TableColumn fx:id="colCant" text="STOCK" prefWidth="60.0" />
                                <TableColumn fx:id="colFecha" text="FECHA" prefWidth="130.0" />
                                <TableColumn fx:id="colTotal" text="TOTAL" prefWidth="90.0" />
                                <TableColumn fx:id="colEstado" text="ESTADO" prefWidth="100.0" />

                            </columns>

                        </TableView>

                    </children>

                </AnchorPane>

            </children>

        </StackPane>

    </children>

</VBox>