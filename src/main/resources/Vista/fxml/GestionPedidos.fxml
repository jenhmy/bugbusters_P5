<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0"
      prefWidth="1127.0"
      spacing="12.0"
      styleClass="vbox-main"
      stylesheets="/Vista/css/estilos.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Vista.controllers.GestionPedidosController">

    <children>

        <VBox alignment="CENTER_LEFT"
              prefHeight="122.0"
              spacing="10.0"
              styleClass="header-bar">

            <children>

                <Label styleClass="label-titulo" text="GESTIÓN DE PEDIDOS · PANEL OPERATIVO Y FINANCIERO">
                    <VBox.margin>
                        <Insets left="20.0" />
                    </VBox.margin>
                </Label>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>

                        <Button onAction="#volverInicio"
                                styleClass="boton-primario"
                                text="⌂ INICIO" />

                        <Button onAction="#mostrarFormulario"
                                styleClass="boton-resaltado"
                                text="🛒 CREAR" />

                        <ComboBox fx:id="comboFiltro"
                                  prefWidth="170.0"
                                  promptText="Filtrar por..."
                                  styleClass="combo-box-steam" />

                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                            <children>
                                <TextField fx:id="txtBuscador"
                                           managed="false"
                                           prefWidth="200.0"
                                           promptText="ID o cliente..."
                                           styleClass="text-field-steam"
                                           visible="false" />

                                <Button fx:id="btnLupa"
                                        onAction="#activarBuscador"
                                        styleClass="boton-primario"
                                        text="🔎" />
                            </children>
                        </HBox>

                        <Button onAction="#cambiarAEnviado"
                                styleClass="boton-primario"
                                text="CAMBIAR A ENVIADO" />

                        <Button onAction="#eliminarElemento"
                                styleClass="boton-eliminar"
                                text="CANCELAR" />

                    </children>

                    <VBox.margin>
                        <Insets left="20.0" />
                    </VBox.margin>
                </HBox>

                <Label fx:id="lblMensaje"
                       styleClass="mensaje-confirmacion">
                    <VBox.margin>
                        <Insets left="20.0" />
                    </VBox.margin>
                </Label>

            </children>

            <padding>
                <Insets bottom="10.0" top="10.0" />
            </padding>

        </VBox>

        <GridPane hgap="12.0"
                  vgap="12.0"
                  style="-fx-background-color: linear-gradient(to bottom right, rgba(10,20,35,0.84), rgba(12,28,46,0.72)); -fx-background-radius: 18; -fx-border-color: rgba(0,240,255,0.16); -fx-border-width: 1; -fx-border-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.32), 14, 0.18, 0, 5);">

            <VBox.margin>
                <Insets left="14.0" right="14.0" />
            </VBox.margin>

            <padding>
                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
            </padding>

            <columnConstraints>
                <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS" />
                <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS" />
                <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS" />
                <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS" />
            </columnConstraints>

            <children>

                <VBox GridPane.columnIndex="0"
                      GridPane.rowIndex="0"
                      alignment="CENTER_LEFT"
                      spacing="4.0"
                      style="-fx-background-color: rgba(255,255,255,0.045); -fx-background-radius: 14; -fx-border-color: rgba(0,240,255,0.18); -fx-border-width: 1; -fx-border-radius: 14;">
                    <padding>
                        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
                    </padding>
                    <children>
                        <Label text="PEDIDOS"
                               style="-fx-text-fill: #67f6ff; -fx-font-size: 12px; -fx-font-weight: bold;" />
                        <Label fx:id="lblTotalPedidos"
                               text="—"
                               style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                        <Label text="registros totales"
                               style="-fx-text-fill: #9fc1d4; -fx-font-size: 11px;" />
                    </children>
                </VBox>

                <VBox GridPane.columnIndex="1"
                      GridPane.rowIndex="0"
                      alignment="CENTER_LEFT"
                      spacing="4.0"
                      style="-fx-background-color: rgba(255,255,255,0.045); -fx-background-radius: 14; -fx-border-color: rgba(255,209,102,0.22); -fx-border-width: 1; -fx-border-radius: 14;">
                    <padding>
                        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
                    </padding>
                    <children>
                        <Label text="PENDIENTES"
                               style="-fx-text-fill: #ffd166; -fx-font-size: 12px; -fx-font-weight: bold;" />
                        <Label fx:id="lblPedidosPendientes"
                               text="—"
                               style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                        <Label text="requieren gestión"
                               style="-fx-text-fill: #9fc1d4; -fx-font-size: 11px;" />
                    </children>
                </VBox>

                <VBox GridPane.columnIndex="2"
                      GridPane.rowIndex="0"
                      alignment="CENTER_LEFT"
                      spacing="4.0"
                      style="-fx-background-color: rgba(255,255,255,0.045); -fx-background-radius: 14; -fx-border-color: rgba(77,255,210,0.22); -fx-border-width: 1; -fx-border-radius: 14;">
                    <padding>
                        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
                    </padding>
                    <children>
                        <Label text="ENVIADOS"
                               style="-fx-text-fill: #4dffd2; -fx-font-size: 12px; -fx-font-weight: bold;" />
                        <Label fx:id="lblPedidosEnviados"
                               text="—"
                               style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                        <Label text="pedidos completados"
                               style="-fx-text-fill: #9fc1d4; -fx-font-size: 11px;" />
                    </children>
                </VBox>

                <VBox GridPane.columnIndex="3"
                      GridPane.rowIndex="0"
                      alignment="CENTER_LEFT"
                      spacing="4.0"
                      style="-fx-background-color: rgba(255,255,255,0.045); -fx-background-radius: 14; -fx-border-color: rgba(255,46,136,0.22); -fx-border-width: 1; -fx-border-radius: 14;">
                    <padding>
                        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
                    </padding>
                    <children>
                        <Label text="FACTURACIÓN TOTAL"
                               style="-fx-text-fill: #ff2e88; -fx-font-size: 12px; -fx-font-weight: bold;" />
                        <Label fx:id="lblFacturacionTotal"
                               text="—"
                               style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" />
                        <Label text="pedidos no cancelados"
                               style="-fx-text-fill: #9fc1d4; -fx-font-size: 11px;" />
                    </children>
                </VBox>

                <VBox GridPane.columnIndex="0"
                      GridPane.rowIndex="1"
                      alignment="CENTER_LEFT"
                      spacing="4.0"
                      style="-fx-background-color: rgba(255,255,255,0.045); -fx-background-radius: 14; -fx-border-color: rgba(157,78,221,0.22); -fx-border-width: 1; -fx-border-radius: 14;">
                    <padding>
                        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
                    </padding>
                    <children>
                        <Label text="FACTURACIÓN MES"
                               style="-fx-text-fill: #c77dff; -fx-font-size: 12px; -fx-font-weight: bold;" />
                        <Label fx:id="lblFacturacionMes"
                               text="—"
                               style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" />
                        <Label text="mes actual"
                               style="-fx-text-fill: #9fc1d4; -fx-font-size: 11px;" />
                    </children>
                </VBox>

                <VBox GridPane.columnIndex="1"
                      GridPane.rowIndex="1"
                      alignment="CENTER_LEFT"
                      spacing="4.0"
                      style="-fx-background-color: rgba(255,255,255,0.045); -fx-background-radius: 14; -fx-border-color: rgba(0,240,255,0.18); -fx-border-width: 1; -fx-border-radius: 14;">
                    <padding>
                        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
                    </padding>
                    <children>
                        <Label text="TICKET MEDIO"
                               style="-fx-text-fill: #67f6ff; -fx-font-size: 12px; -fx-font-weight: bold;" />
                        <Label fx:id="lblTicketMedio"
                               text="—"
                               style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" />
                        <Label text="importe medio"
                               style="-fx-text-fill: #9fc1d4; -fx-font-size: 11px;" />
                    </children>
                </VBox>

                <VBox GridPane.columnIndex="2"
                      GridPane.columnSpan="2"
                      GridPane.rowIndex="1"
                      alignment="CENTER_LEFT"
                      spacing="4.0"
                      style="-fx-background-color: rgba(255,255,255,0.045); -fx-background-radius: 14; -fx-border-color: rgba(77,255,210,0.22); -fx-border-width: 1; -fx-border-radius: 14;">
                    <padding>
                        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
                    </padding>
                    <children>
                        <Label text="PEDIDO DE MAYOR IMPORTE"
                               style="-fx-text-fill: #4dffd2; -fx-font-size: 12px; -fx-font-weight: bold;" />
                        <Label fx:id="lblMayorImporte"
                               text="—"
                               wrapText="true"
                               style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />
                        <Label text="referencia comercial destacada"
                               style="-fx-text-fill: #9fc1d4; -fx-font-size: 11px;" />
                    </children>
                </VBox>

            </children>

        </GridPane>

        <StackPane VBox.vgrow="ALWAYS">

            <children>

                <AnchorPane styleClass="table-container">

                    <children>

                        <TableView fx:id="tvTabla"
                                   AnchorPane.bottomAnchor="15.0"
                                   AnchorPane.leftAnchor="15.0"
                                   AnchorPane.rightAnchor="15.0"
                                   AnchorPane.topAnchor="15.0">

                            <columns>

                                <TableColumn fx:id="colId" text="ID" prefWidth="70.0" />
                                <TableColumn fx:id="colCliente" text="CLIENTE" prefWidth="170.0" />
                                <TableColumn fx:id="colArticulo" text="ARTÍCULO" prefWidth="210.0" />
                                <TableColumn fx:id="colCant" text="CANTIDAD" prefWidth="85.0" />
                                <TableColumn fx:id="colFecha" text="FECHA" prefWidth="145.0" />
                                <TableColumn fx:id="colTotal" text="TOTAL" prefWidth="100.0" />
                                <TableColumn fx:id="colEstado" text="ESTADO" prefWidth="110.0" />

                            </columns>

                        </TableView>

                    </children>

                </AnchorPane>

            </children>

        </StackPane>

    </children>

</VBox>