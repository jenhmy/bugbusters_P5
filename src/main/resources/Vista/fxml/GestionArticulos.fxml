<?xml version="1.0" encoding="UTF-8"?>

<!-- Importaciones de JavaFX utilizadas en la vista -->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!-- Vista de gestión de artículos -->
<VBox prefHeight="600.0"
      prefWidth="1127.0"
      spacing="10.0"
      styleClass="vbox-main"
      stylesheets="/Vista/css/estilos.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Vista.controllers.GestionArticulosController">

    <children>

        <!-- CABECERA SUPERIOR -->
        <VBox alignment="CENTER_LEFT"
              prefHeight="120.0"
              spacing="10.0"
              styleClass="header-bar">

            <children>

                <!-- Título de la pantalla -->
                <Label styleClass="label-titulo" text="GESTIÓN DE ARTÍCULOS">
                    <VBox.margin>
                        <Insets left="20.0" />
                    </VBox.margin>
                </Label>

                <!-- Barra de acciones -->
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>

                        <!-- Botón para crear artículo -->
                        <Button onAction="#mostrarFormulario"
                                styleClass="boton-resaltado"
                                text="📦 CREAR" />

                        <!-- Filtro de artículos -->
                        <ComboBox fx:id="comboFiltro"
                                  prefWidth="180.0"
                                  promptText="Filtrar por..."
                                  styleClass="combo-box-steam" />

                        <!-- Buscador oculto -->
                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                            <children>
                                <TextField fx:id="txtBuscador"
                                           managed="false"
                                           prefWidth="200.0"
                                           promptText="Escribe código..."
                                           styleClass="text-field-steam"
                                           visible="false" />

                                <Button fx:id="btnLupa"
                                        onAction="#activarBuscador"
                                        styleClass="boton-primario"
                                        text="🔎" />
                            </children>
                        </HBox>

                        <!-- Acción eliminar -->
                        <Button onAction="#eliminarElemento"
                                styleClass="boton-eliminar"
                                text="ELIMINAR" />

                    </children>

                    <VBox.margin>
                        <Insets left="20.0" />
                    </VBox.margin>
                </HBox>

                <!-- Mensajes de estado -->
                <Label fx:id="lblMensaje"
                       styleClass="mensaje-confirmacion">
                    <VBox.margin>
                        <Insets left="20.0" />
                    </VBox.margin>
                </Label>

            </children>

            <padding>
                <Insets bottom="10.0" top="10.0" />
            </padding>

        </VBox>

        <!-- ZONA CENTRAL: TABLA DE ARTÍCULOS -->
        <StackPane VBox.vgrow="ALWAYS">

            <children>

                <AnchorPane styleClass="table-container">

                    <children>

                        <!-- Tabla principal -->
                        <TableView fx:id="tvTabla"
                                   AnchorPane.bottomAnchor="15.0"
                                   AnchorPane.leftAnchor="15.0"
                                   AnchorPane.rightAnchor="15.0"
                                   AnchorPane.topAnchor="15.0">

                            <columns>

                                <!-- Columnas de artículos -->
                                <TableColumn fx:id="colCodigo" text="CÓDIGO" prefWidth="80.0" />
                                <TableColumn fx:id="colDesc" text="DESCRIPCIÓN" prefWidth="200.0" />
                                <TableColumn fx:id="colPrecio" text="PRECIO" prefWidth="90.0" />
                                <TableColumn fx:id="colEnvio" text="ENVÍO" prefWidth="90.0" />
                                <TableColumn fx:id="colPrep" text="TIEMPO PREP." prefWidth="150.0" />
                                <TableColumn fx:id="colStock" text="STOCK" prefWidth="80.0" />

                            </columns>

                        </TableView>

                    </children>

                </AnchorPane>

            </children>

        </StackPane>

    </children>

</VBox>