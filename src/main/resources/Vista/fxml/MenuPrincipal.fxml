<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane"
            prefHeight="780.0"
            prefWidth="1280.0"
            styleClass="root-pane"
            stylesheets="/Vista/css/estilos.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Vista.controllers.MenuPrincipalController">

    <left>
        <VBox prefWidth="250.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>

                <!-- BLOQUE LOGO -->
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <ImageView fx:id="imgLogo" fitHeight="80.0" fitWidth="80.0"
                                   pickOnBounds="true" preserveRatio="true" />
                        <Label styleClass="logo-text" text="BUGBUSTERS">
                            <font><Font name="Verdana Bold" size="20.0" /></font>
                        </Label>
                        <Label styleClass="sub-logo-text" text="TIENDA DE PRODUCTOS" />
                    </children>
                    <VBox.margin><Insets bottom="32.0" top="20.0" /></VBox.margin>
                </VBox>

                <!-- ETIQUETA DE SECCIÓN -->
                <Label styleClass="section-label" text="NAVEGACIÓN">
                    <VBox.margin><Insets bottom="8.0" left="20.0" /></VBox.margin>
                </Label>

                <!-- BOTONES DE NAVEGACIÓN -->
                <VBox spacing="6.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="btnArticulos" alignment="BASELINE_LEFT"
                                maxWidth="1.7976931348623157E308"
                                onAction="#abrirArticulos"
                                prefHeight="44.0"
                                styleClass="boton-lateral"
                                text="📦   ARTÍCULOS">
                            <padding><Insets left="26.0" /></padding>
                        </Button>
                        <Button fx:id="btnClientes" alignment="BASELINE_LEFT"
                                maxWidth="1.7976931348623157E308"
                                onAction="#abrirClientes"
                                prefHeight="44.0"
                                styleClass="boton-lateral"
                                text="👥   CLIENTES">
                            <padding><Insets left="26.0" /></padding>
                        </Button>
                        <Button fx:id="btnPedidos" alignment="BASELINE_LEFT"
                                maxWidth="1.7976931348623157E308"
                                onAction="#abrirPedidos"
                                prefHeight="44.0"
                                styleClass="boton-lateral"
                                text="🛒   PEDIDOS">
                            <padding><Insets left="26.0" /></padding>
                        </Button>
                    </children>
                </VBox>

                <!-- PANEL DE ESTADO HUD -->
                <VBox spacing="8.0" styleClass="hud-panel">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Circle fx:id="statusDot" radius="4.0" styleClass="status-dot" />
                                <Label fx:id="lblStatus" styleClass="hud-status" text="SISTEMA EN LÍNEA" />
                            </children>
                        </HBox>
                        <Label fx:id="lblHora" styleClass="hud-clock" text="--:--:--" />
                        <Label styleClass="hud-version" text="v 5.0 · BUGBUSTERS CORE" />
                    </children>
                    <VBox.margin><Insets bottom="14.0" left="18.0" right="18.0" top="14.0" /></VBox.margin>
                </VBox>

                <!-- BOTÓN SALIR -->
                <Button fx:id="btnSalir" maxWidth="1.7976931348623157E308"
                        onAction="#salirApp" prefHeight="40.0"
                        styleClass="boton-salir" text="SALIR">
                    <VBox.margin><Insets bottom="20.0" left="20.0" right="20.0" /></VBox.margin>
                </Button>

            </children>
            <BorderPane.margin><Insets bottom="10.0" right="10.0" top="10.0" /></BorderPane.margin>
        </VBox>
    </left>

    <center>
        <AnchorPane fx:id="areaContenido" styleClass="area-contenido" BorderPane.alignment="CENTER">
            <BorderPane.margin><Insets bottom="10.0" right="10.0" top="10.0" /></BorderPane.margin>
            <!-- Contenido inicial inyectado por el controlador (dashboard) -->
        </AnchorPane>
    </center>
</BorderPane>