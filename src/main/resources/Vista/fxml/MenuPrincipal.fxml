<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane"
            prefHeight="650.0"
            prefWidth="1127.0"
            styleClass="root-pane"
            stylesheets="/Vista/css/estilos.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Vista.controllers.MenuPrincipalController">

    <left>
        <VBox prefWidth="250.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <ImageView fx:id="imgLogo" fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true" />
                        <Label styleClass="logo-text" text="BUGBUSTERS">
                            <font><Font name="Verdana Bold" size="20.0" /></font>
                        </Label>
                        <Label styleClass="sub-logo-text" text="TIENDA DE PRODUCTOS" />
                    </children>
                    <VBox.margin><Insets bottom="40.0" top="30.0" /></VBox.margin>
                </VBox>

                <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="btnArticulos" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#abrirArticulos" prefHeight="45.0" styleClass="boton-lateral" text="📦   ARTÍCULOS">
                            <padding><Insets left="30.0" /></padding>
                        </Button>
                        <Button fx:id="btnClientes" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#abrirClientes" prefHeight="45.0" styleClass="boton-lateral" text="👥   CLIENTES">
                            <padding><Insets left="30.0" /></padding>
                        </Button>
                        <Button fx:id="btnPedidos" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#abrirPedidos" prefHeight="45.0" styleClass="boton-lateral" text="🛒   PEDIDOS">
                            <padding><Insets left="30.0" /></padding>
                        </Button>
                    </children>
                </VBox>

                <Button fx:id="btnSalir" maxWidth="1.7976931348623157E308" onAction="#salirApp" prefHeight="40.0" styleClass="boton-salir" text="SALIR">
                    <VBox.margin><Insets bottom="20.0" left="20.0" right="20.0" /></VBox.margin>
                </Button>
            </children>
            <BorderPane.margin><Insets bottom="10.0" right="10.0" top="10.0" /></BorderPane.margin>
        </VBox>
    </left>

    <center>
        <AnchorPane fx:id="areaContenido" styleClass="area-contenido" BorderPane.alignment="CENTER">
            <BorderPane.margin><Insets bottom="10.0" right="10.0" top="10.0" /></BorderPane.margin>
            <children>
                <VBox alignment="CENTER" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Label styleClass="titulo-inicio" text="INICIO" />
                        <Label styleClass="subtitulo-inicio" text="Software de gestión BugBusters" />
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </center>
</BorderPane>